# Port to run the health check server on (default: 3001)
PORT=3001

# RabbitMQ configuration
RABBITMQ_URL=amqp://localhost
RABBITMQ_EXCHANGE=linkerin.scrape
RABBITMQ_QUEUE=linkerin.scrape.jobs

# Normal Backend Webhook Configuration
NORMAL_BACKEND_URL=http://localhost:3000
CALLBACK_SECRET=your-shared-callback-webhook-secret
