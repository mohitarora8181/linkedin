# =========================================================================
# LINKEDIN SCRAPER WORKSPACE ENV TEMPLATE
# Copy the appropriate settings into scraping-backend/.env and normal-backend/.env
# =========================================================================

# -------------------------------------------------------------------------
# SCRAPING BACKEND ENV CONFIG (Required in scraping-backend/.env)
# -------------------------------------------------------------------------
# RABBITMQ_URL=amqp://localhost
# RABBITMQ_EXCHANGE=linkerin.scrape
# RABBITMQ_QUEUE=linkerin.scrape.jobs
# RABBITMQ_AI_QUEUE=groq_ai_parsing
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------------------------------------------------------
# NORMAL BACKEND ENV CONFIG (Required in normal-backend/.env)
# -------------------------------------------------------------------------
# PORT=3000
# RABBITMQ_URL=amqp://localhost
# RABBITMQ_EXCHANGE=linkerin.scrape
# RABBITMQ_QUEUE=linkerin.scrape.jobs
# RABBITMQ_AI_QUEUE=groq_ai_parsing
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3.1-flash-lite
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=qwen/qwen3-32b
